{
  "manifest_version": 3,
  "name": "Spara",
  "description": "Save any link to your Spara library with one click.",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage", "identity"],
  "host_permissions": ["https://app.usespara.com/*", "https://khsklfanpzheiubjtxyk.supabase.co/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Save to Spara"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
